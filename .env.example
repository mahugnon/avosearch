# Database (docker-compose exposes Postgres on host port 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/lexpresso

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=change-me

# LLM — NVIDIA NIM (Nemotron)
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Stripe — test keys for dev; live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Local webhook forwarding: npm run stripe:listen

# App URL (required for Stripe redirects and emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (optional — logs to console if unset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AvoSearch <noreply@avosearch.test>

# Optional pricing overrides (cents, TTC). Defaults live in lib/config.ts.
# PRICE_AI_ONLY_CENTS=1900
# PRICE_AI_BARRISTER_CENTS=7900
# PRICE_MISSION_MIN_CENTS=15000
# PRICE_MISSION_MAX_CENTS=50000
